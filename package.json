{
  "name": "print-occ-debug-viewer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.config.ts",
    "build": "npm run typecheck && vite build --config vite.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "preview": "vite preview --config vite.config.ts"
  },
  "dependencies": {
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "three": "0.184.0",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/three": "0.184.1",
    "@vitejs/plugin-react": "6.0.2",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "4.1.9"
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/liyongzheng666/Print/protocol/session.schema.json",
  "title": "Print geometry debug session",
  "type": "object",
  "required": [
    "schema_version",
    "session_id",
    "created_at",
    "unit",
    "coordinate_system",
    "occt_version"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "session_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "document": { "type": "string" },
    "target_object": { "type": "string" },
    "unit": { "enum": ["mm", "cm", "m", "in"] },
    "coordinate_system": { "const": "right_handed_z_up" },
    "freecad_revision": { "type": "string" },
    "occt_version": { "type": "string" },
    "occt_revision": { "type": "string" },
    "print_revision": { "type": "string" },
    "baseline": {
      "type": "object",
      "properties": {
        "object_name": { "type": "string" },
        "asset": { "type": "string" },
        "placement_strategy": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
